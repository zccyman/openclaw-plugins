{
  "id": "openharness",
  "name": "OpenHarness",
  "description": "Unified OpenHarness plugin — auth, bridge, code-intel, commands, context, cost, gitflow, github, governance, interactive, lsp, mcp, memory, provider, repl, session, session-ops, skills, structured-output, swarm, and 43+ core tools",
  "version": "1.0.0",
  "enabledByDefault": true,
  "channels": ["openharness"],
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "allowedTools": {
        "type": "array",
        "items": { "type": "string" },
        "description": "Subset of OpenHarness tools to expose (empty = all)"
      },
      "mcpServers": {
        "type": "object",
        "additionalProperties": true,
        "description": "MCP server configurations to connect to"
      },
      "governance": {
        "type": "object",
        "additionalProperties": true,
        "description": "Governance and permission settings"
      },
      "model": {
        "type": "string",
        "description": "Default model for cost tracking and provider selection"
      },
      "fastModel": {
        "type": "string",
        "description": "Fast/cheap model for quick responses"
      }
    }
  },
  "contracts": {
    "tools": [
      "oh_bash", "oh_file_read", "oh_file_write", "oh_file_edit",
      "oh_glob", "oh_grep", "oh_web_fetch", "oh_web_search",
      "oh_skill", "oh_config", "oh_brief", "oh_todo_write",
      "oh_enter_plan_mode", "oh_exit_plan_mode",
      "oh_task_create", "oh_task_get", "oh_task_list", "oh_task_stop", "oh_task_output", "oh_task_update",
      "oh_agent_spawn", "oh_send_message",
      "oh_team_create", "oh_team_delete",
      "oh_cron_create", "oh_cron_list", "oh_cron_delete",
      "oh_notebook_edit",
      "oh_auth_status", "oh_auth_login", "oh_auth_logout",
      "oh_bridge_spawn", "oh_bridge_send", "oh_bridge_receive", "oh_bridge_close", "oh_bridge_list",
      "oh_code_symbol_search", "oh_code_definitions", "oh_code_references", "oh_code_dependencies", "oh_code_outline", "oh_code_complexity",
      "oh_context_discover", "oh_context_compress", "oh_context_estimate_tokens", "oh_context_status", "oh_context_add_instruction",
      "oh_cost_track", "oh_cost_summary", "oh_model_set", "oh_model_list", "oh_effort_set", "oh_passes_set", "oh_usage_stats", "oh_fast_mode",
      "oh_git_smart_commit", "oh_git_branch_manager", "oh_git_pr_description", "oh_git_changelog", "oh_git_worktree", "oh_git_status_dashboard",
      "oh_github_issue_create", "oh_github_issue_list", "oh_github_issue_get", "oh_github_issue_comment", "oh_github_pr_comments", "oh_github_pr_review",
      "oh_permissions",
      "oh_ask_user_question", "oh_confirm_action", "oh_select_from_list", "oh_input_text",
      "oh_lsp_definition", "oh_lsp_references", "oh_lsp_hover", "oh_lsp_diagnostics", "oh_lsp_rename", "oh_lsp_symbols", "oh_lsp_implementation", "oh_lsp_completions",
      "oh_mcp_connect", "oh_mcp_disconnect", "oh_mcp_list_servers", "oh_mcp_list_tools", "oh_mcp_call_tool", "oh_mcp_list_resources", "oh_mcp_read_resource", "oh_mcp_server_status",
      "oh_memory_add", "oh_memory_list", "oh_memory_search", "oh_memory_remove", "oh_memory_view",
      "oh_provider_list", "oh_provider_set", "oh_provider_test", "oh_model_alias",
      "oh_repl_execute", "oh_repl_list_runtimes", "oh_repl_install_runtime",
      "oh_session_save", "oh_session_load", "oh_session_list", "oh_session_export", "oh_session_branch", "oh_session_summary",
      "oh_session_context", "oh_session_rewind", "oh_session_tag", "oh_session_share", "oh_project_init", "oh_plugin_reload", "oh_config_runtime", "oh_version",
      "oh_skill_list", "oh_skill_load", "oh_skill_search",
      "oh_structured_output", "oh_output_template",
